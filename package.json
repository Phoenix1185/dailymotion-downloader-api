{
  "name": "dailymotion-downloader-api",
  "version": "1.0.0",
  "description": "Production-ready DailyMotion Video Downloader API with OAuth, API Keys, Paystack Payments, and Neon DB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/utils/seed.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "dailymotion",
    "video-downloader",
    "api",
    "oauth",
    "api-keys",
    "paystack",
    "payments",
    "neon-db",
    "postgresql"
  ],
  "author": "Phoenix (@CryptoPhoenixz)",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "argon2": "^0.40.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jose": "^5.2.3",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
